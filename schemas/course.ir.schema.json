{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hewimetall/mcp-stepik/schemas/course.ir.schema.json",
  "title": "CourseIR",
  "type": "object",
  "required": ["course", "sections"],
  "properties": {
    "course": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "language": { "type": "string" },
        "course_id": { "type": ["integer", "null"] }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "maxLength": 64 },
                "is_public": { "type": "boolean" },
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["type"],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "text",
                          "choice",
                          "code",
                          "video",
                          "string",
                          "number",
                          "matching",
                          "sorting",
                          "free-answer",
                          "review"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
